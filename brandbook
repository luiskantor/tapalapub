<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tapa La Pub — Brand Book</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Headland+One&display=swap" rel="stylesheet">
<style>
@font-face {
  font-family: 'Haskoy';
  src: url('https://haskoy.ertekinn.com/fonts/Haskoy-Regular.woff2') format('woff2');
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Haskoy';
  src: url('https://haskoy.ertekinn.com/fonts/Haskoy-Medium.woff2') format('woff2');
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Haskoy';
  src: url('https://haskoy.ertekinn.com/fonts/Haskoy-SemiBold.woff2') format('woff2');
  font-weight: 600;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Haskoy';
  src: url('https://haskoy.ertekinn.com/fonts/Haskoy-Bold.woff2') format('woff2');
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Haskoy';
  src: url('https://haskoy.ertekinn.com/fonts/Haskoy-Light.woff2') format('woff2');
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Haskoy';
  src: url('https://haskoy.ertekinn.com/fonts/Haskoy-ExtraLight.woff2') format('woff2');
  font-weight: 200;
  font-style: normal;
  font-display: swap;
}

:root {
  --cream: #F5EFE0;
  --cream-light: #FAF7F0;
  --cream-dark: #E8DFC8;
  --anthracite: #2A2A2A;
  --anthracite-light: #3D3D3D;
  --anthracite-mid: #4A4A4A;
  --gold: #D89928;
  --gold-light: #E5B54E;
  --gold-dark: #B87D1A;
  --gold-muted: #C4943F;
  --white: #FFFFFF;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html {
  scroll-behavior: smooth;
  scroll-snap-type: y proximity;
}

body {
  font-family: 'Haskoy', 'Segoe UI', sans-serif;
  background: var(--cream);
  color: var(--anthracite);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ==================== NAV ==================== */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 20px 48px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  mix-blend-mode: difference;
  transition: opacity 0.3s;
}
.nav-label {
  font-family: 'Headland One', serif;
  font-size: 14px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--cream);
}
.nav-dots {
  display: flex;
  gap: 8px;
}
.nav-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--cream);
  opacity: 0.4;
  cursor: pointer;
  transition: all 0.3s;
}
.nav-dot.active, .nav-dot:hover {
  opacity: 1;
  transform: scale(1.3);
}

/* ==================== SECTIONS ==================== */
.section {
  min-height: 100vh;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  scroll-snap-align: start;
  overflow: hidden;
}

/* ==================== COVER ==================== */
.cover {
  background: var(--anthracite);
  flex-direction: column;
  gap: 32px;
}
.cover::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 20% 80%, rgba(216,153,40,0.08) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 20%, rgba(216,153,40,0.05) 0%, transparent 50%);
}
.cover-logo {
  width: 320px;
  max-width: 60vw;
  position: relative;
  z-index: 2;
  animation: fadeUp 1.2s ease-out;
}
.cover-subtitle {
  font-family: 'Haskoy', sans-serif;
  font-weight: 400;
  font-size: 14px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--gold);
  position: relative;
  z-index: 2;
  animation: fadeUp 1.2s ease-out 0.3s both;
}
.cover-line {
  width: 60px;
  height: 1px;
  background: var(--gold);
  position: relative;
  z-index: 2;
  animation: fadeUp 1.2s ease-out 0.5s both;
}
.cover-title {
  font-family: 'Headland One', serif;
  font-size: clamp(28px, 4vw, 48px);
  color: var(--cream);
  letter-spacing: 0.08em;
  position: relative;
  z-index: 2;
  animation: fadeUp 1.2s ease-out 0.6s both;
}
.cover-year {
  font-family: 'Haskoy', sans-serif;
  font-weight: 200;
  font-size: 13px;
  letter-spacing: 0.3em;
  color: rgba(245,239,224,0.35);
  position: absolute;
  bottom: 48px;
  z-index: 2;
  animation: fadeUp 1.2s ease-out 0.9s both;
}

/* ==================== BRAND STORY ==================== */
.brand-story {
  background: var(--cream);
  padding: 120px 48px;
}
.brand-story-inner {
  max-width: 900px;
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 80px;
  align-items: start;
}
.section-label {
  font-family: 'Haskoy', sans-serif;
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gold);
  padding-top: 12px;
  position: sticky;
  top: 120px;
}
.section-label::after {
  content: '';
  display: block;
  width: 32px;
  height: 2px;
  background: var(--gold);
  margin-top: 16px;
}
.brand-story-text h2 {
  font-family: 'Headland One', serif;
  font-size: clamp(28px, 3.5vw, 44px);
  line-height: 1.25;
  color: var(--anthracite);
  margin-bottom: 40px;
}
.brand-story-text h2 em {
  color: var(--gold);
  font-style: normal;
}
.brand-story-text p {
  font-size: 17px;
  line-height: 1.8;
  color: var(--anthracite-mid);
  margin-bottom: 24px;
  font-weight: 400;
}

/* ==================== LOGO SECTION ==================== */
.logo-section {
  background: var(--cream-light);
  padding: 120px 48px;
  flex-direction: column;
}
.logo-section-inner {
  max-width: 1100px;
  width: 100%;
}
.logo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32px;
  margin-top: 64px;
}
.logo-card {
  border-radius: 16px;
  padding: 64px 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 24px;
  position: relative;
  min-height: 300px;
}
.logo-card img {
  max-width: 260px;
  width: 100%;
}
.logo-card-dark {
  background: var(--anthracite);
}
.logo-card-cream {
  background: var(--cream-dark);
}
.logo-card-gold {
  background: var(--gold);
}
.logo-card-white {
  background: var(--white);
  border: 1px solid rgba(42,42,42,0.08);
}
.logo-card-label {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 500;
  position: absolute;
  bottom: 24px;
}
.logo-card-dark .logo-card-label { color: rgba(245,239,224,0.5); }
.logo-card-cream .logo-card-label { color: var(--anthracite-mid); }
.logo-card-gold .logo-card-label { color: rgba(42,42,42,0.6); }
.logo-card-white .logo-card-label { color: var(--anthracite-mid); }

.logo-spacing {
  margin-top: 64px;
  padding: 48px;
  background: var(--white);
  border-radius: 16px;
  border: 1px solid rgba(42,42,42,0.06);
}
.logo-spacing h4 {
  font-family: 'Headland One', serif;
  font-size: 20px;
  margin-bottom: 16px;
  color: var(--anthracite);
}
.logo-spacing p {
  font-size: 15px;
  line-height: 1.7;
  color: var(--anthracite-mid);
  font-weight: 400;
}

/* ==================== COLORS ==================== */
.colors-section {
  background: var(--anthracite);
  padding: 120px 48px;
  flex-direction: column;
}
.colors-inner {
  max-width: 1100px;
  width: 100%;
}
.colors-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 64px;
}
.colors-header h2 {
  font-family: 'Headland One', serif;
  font-size: clamp(32px, 4vw, 52px);
  color: var(--cream);
}
.colors-header p {
  color: rgba(245,239,224,0.5);
  font-weight: 400;
  font-size: 15px;
  max-width: 300px;
  text-align: right;
  line-height: 1.6;
}

.color-palette {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.color-card {
  border-radius: 16px;
  overflow: hidden;
  background: rgba(255,255,255,0.04);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.06);
}
.color-swatch {
  height: 200px;
  position: relative;
}
.color-swatch::after {
  content: attr(data-name);
  position: absolute;
  bottom: 16px;
  left: 24px;
  font-family: 'Headland One', serif;
  font-size: 20px;
}
.swatch-cream { background: var(--cream); }
.swatch-cream::after { color: var(--anthracite); }
.swatch-anthracite { background: var(--anthracite); border: 1px solid rgba(255,255,255,0.1); }
.swatch-anthracite::after { color: var(--cream); }
.swatch-gold { background: var(--gold); }
.swatch-gold::after { color: var(--anthracite); }

.color-info {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.color-value {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  font-weight: 400;
  color: rgba(245,239,224,0.6);
}
.color-value span:last-child {
  font-family: 'SF Mono', 'Fira Code', monospace;
  color: rgba(245,239,224,0.8);
  font-size: 12px;
}

/* Secondary colors */
.colors-secondary {
  margin-top: 48px;
}
.colors-secondary h3 {
  font-family: 'Headland One', serif;
  font-size: 22px;
  color: var(--cream);
  margin-bottom: 32px;
}
.secondary-swatches {
  display: flex;
  gap: 16px;
}
.secondary-swatch {
  flex: 1;
  height: 80px;
  border-radius: 12px;
  position: relative;
  display: flex;
  align-items: flex-end;
  padding: 12px 16px;
}
.secondary-swatch span {
  font-size: 11px;
  letter-spacing: 0.1em;
  font-weight: 500;
}

/* ==================== TYPOGRAPHY ==================== */
.type-section {
  background: var(--cream);
  padding: 120px 48px;
  flex-direction: column;
}
.type-inner {
  max-width: 1100px;
  width: 100%;
}
.type-header {
  margin-bottom: 80px;
}
.type-header h2 {
  font-family: 'Headland One', serif;
  font-size: clamp(32px, 4vw, 52px);
  color: var(--anthracite);
  margin-bottom: 16px;
}
.type-header p {
  font-size: 17px;
  color: var(--anthracite-mid);
  font-weight: 400;
  max-width: 500px;
  line-height: 1.7;
}
.type-showcase {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
}
.type-card {
  background: var(--white);
  border-radius: 16px;
  padding: 48px;
  border: 1px solid rgba(42,42,42,0.06);
}
.type-card-dark {
  background: var(--anthracite);
}
.type-card-label {
  font-size: 11px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--gold);
  margin-bottom: 32px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.type-card-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(216,153,40,0.3);
}
.type-specimen {
  font-family: 'Headland One', serif;
  font-size: clamp(40px, 5vw, 64px);
  line-height: 1.15;
  color: var(--anthracite);
  margin-bottom: 32px;
}
.type-card-dark .type-specimen {
  color: var(--cream);
}
.type-body-specimen {
  font-family: 'Haskoy', sans-serif;
  font-size: 32px;
  line-height: 1.3;
  color: var(--anthracite);
  margin-bottom: 32px;
  font-weight: 400;
}
.type-card-dark .type-body-specimen {
  color: var(--cream);
}
.type-meta {
  font-size: 13px;
  color: var(--anthracite-mid);
  font-weight: 400;
  line-height: 1.7;
}
.type-card-dark .type-meta {
  color: rgba(245,239,224,0.5);
}
.type-weights {
  margin-top: 48px;
  padding: 48px;
  background: var(--white);
  border-radius: 16px;
  border: 1px solid rgba(42,42,42,0.06);
}
.type-weights h4 {
  font-family: 'Headland One', serif;
  font-size: 20px;
  margin-bottom: 32px;
}
.weight-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16px 0;
  border-bottom: 1px solid rgba(42,42,42,0.06);
}
.weight-row:last-child { border: none; }
.weight-name {
  font-size: 13px;
  color: var(--anthracite-mid);
  font-weight: 400;
  width: 120px;
}
.weight-sample {
  font-family: 'Haskoy', sans-serif;
  font-size: 24px;
  color: var(--anthracite);
  flex: 1;
}
.weight-value {
  font-size: 12px;
  font-family: 'SF Mono', 'Fira Code', monospace;
  color: var(--anthracite-mid);
}

/* ==================== HIERARCHY ==================== */
.hierarchy-section {
  background: var(--anthracite);
  padding: 120px 48px;
  flex-direction: column;
}
.hierarchy-inner {
  max-width: 900px;
  width: 100%;
}
.hierarchy-inner h2 {
  font-family: 'Headland One', serif;
  font-size: clamp(28px, 3.5vw, 40px);
  color: var(--cream);
  margin-bottom: 64px;
}
.hierarchy-item {
  padding: 40px 0;
  border-bottom: 1px solid rgba(245,239,224,0.08);
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 40px;
  align-items: baseline;
}
.hierarchy-meta {
  font-size: 12px;
  color: rgba(245,239,224,0.4);
  font-weight: 400;
  line-height: 1.8;
}
.h-display {
  font-family: 'Headland One', serif;
  font-size: 52px;
  color: var(--cream);
  line-height: 1.2;
}
.h-h1 {
  font-family: 'Headland One', serif;
  font-size: 40px;
  color: var(--cream);
  line-height: 1.2;
}
.h-h2 {
  font-family: 'Headland One', serif;
  font-size: 32px;
  color: var(--cream);
  line-height: 1.3;
}
.h-h3 {
  font-family: 'Headland One', serif;
  font-size: 24px;
  color: var(--cream);
  line-height: 1.3;
}
.h-body {
  font-family: 'Haskoy', sans-serif;
  font-size: 17px;
  color: rgba(245,239,224,0.7);
  line-height: 1.8;
  font-weight: 400;
}
.h-caption {
  font-family: 'Haskoy', sans-serif;
  font-size: 13px;
  color: rgba(245,239,224,0.5);
  line-height: 1.6;
  font-weight: 400;
  letter-spacing: 0.03em;
}

/* ==================== DESIGN ELEMENTS ==================== */
.elements-section {
  background: var(--cream-light);
  padding: 120px 48px;
  flex-direction: column;
}
.elements-inner {
  max-width: 1100px;
  width: 100%;
}
.elements-header {
  margin-bottom: 64px;
}
.elements-header h2 {
  font-family: 'Headland One', serif;
  font-size: clamp(32px, 4vw, 52px);
  color: var(--anthracite);
  margin-bottom: 16px;
}
.elements-header p {
  font-size: 17px;
  color: var(--anthracite-mid);
  font-weight: 400;
  max-width: 500px;
  line-height: 1.7;
}
.elements-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.element-card {
  background: var(--white);
  border-radius: 16px;
  padding: 40px;
  border: 1px solid rgba(42,42,42,0.06);
  min-height: 220px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.element-card h4 {
  font-family: 'Headland One', serif;
  font-size: 18px;
  color: var(--anthracite);
  margin-bottom: 12px;
}
.element-card p {
  font-size: 14px;
  color: var(--anthracite-mid);
  font-weight: 400;
  line-height: 1.7;
}
.element-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 20px;
}

/* Leaf divider decoration */
.leaf-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  padding: 24px 0;
}
.leaf-divider .line {
  width: 60px;
  height: 1px;
  background: var(--gold);
  opacity: 0.4;
}
.leaf-divider svg {
  width: 24px;
  height: 24px;
  fill: var(--gold);
  opacity: 0.6;
}

/* ==================== FOOTER ==================== */
.footer {
  background: var(--anthracite);
  padding: 80px 48px;
  text-align: center;
  min-height: auto;
}
.footer-logo {
  width: 180px;
  margin: 0 auto 24px;
  opacity: 0.6;
}
.footer p {
  font-size: 13px;
  color: rgba(245,239,224,0.3);
  font-weight: 400;
  letter-spacing: 0.1em;
}


/* ==================== DOWNLOAD BUTTONS ==================== */
.logo-card-download {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 36px;
  height: 36px;
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.15);
  background: rgba(0,0,0,0.25);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  opacity: 0;
  transition: all 0.3s;
  z-index: 5;
}
.logo-card:hover .logo-card-download {
  opacity: 1;
}
.logo-card-download:hover {
  background: var(--gold);
  border-color: var(--gold);
  transform: scale(1.08);
}
.logo-card-download svg {
  width: 16px;
  height: 16px;
}
.logo-card-cream .logo-card-download,
.logo-card-white .logo-card-download {
  border-color: rgba(0,0,0,0.1);
  background: rgba(255,255,255,0.7);
}
.logo-card-cream .logo-card-download:hover,
.logo-card-white .logo-card-download:hover {
  background: var(--gold);
  border-color: var(--gold);
}

/* ==================== ANIMATIONS ==================== */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }

/* ==================== RESPONSIVE ==================== */
@media (max-width: 768px) {
  .brand-story-inner { grid-template-columns: 1fr; gap: 32px; }
  .section-label { position: static; }
  .logo-grid { grid-template-columns: 1fr; }
  .color-palette { grid-template-columns: 1fr; }
  .type-showcase { grid-template-columns: 1fr; }
  .elements-grid { grid-template-columns: 1fr; }
  .hierarchy-item { grid-template-columns: 1fr; gap: 12px; }
  .colors-header { flex-direction: column; gap: 24px; align-items: flex-start; }
  .colors-header p { text-align: left; }
  .nav { padding: 16px 24px; }
  .section { padding-left: 24px; padding-right: 24px; }
  .secondary-swatches { flex-wrap: wrap; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <span class="nav-label">Tapa La Pub</span>
  <div class="nav-dots">
    <div class="nav-dot active" data-section="0"></div>
    <div class="nav-dot" data-section="1"></div>
    <div class="nav-dot" data-section="2"></div>
    <div class="nav-dot" data-section="3"></div>
    <div class="nav-dot" data-section="4"></div>
    <div class="nav-dot" data-section="5"></div>
    <div class="nav-dot" data-section="6"></div>
    
  </div>
</nav>

<!-- 01 COVER -->
<section class="section cover" id="s0">
  <img class="cover-logo" src="data:image/png;base64," alt="Tapa La Pub Logo">
  <div class="cover-line"></div>
  <span class="cover-subtitle">Brand Guidelines</span>
  <h1 class="cover-title">Website Brand Book</h1>
  <span class="cover-year">2026 — Version 1.0</span>
</section>

<!-- 02 BRAND STORY -->
<section class="section brand-story" id="s1">
  <div class="brand-story-inner">
