<script>
// Replace  at runtime
document.addEventListener('DOMContentLoaded', () => {
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  
  // Logo download
  window.downloadLogo = function(btn) {
    const card = btn.closest('.logo-card');
    const img = card.querySelector('img');
    const label = card.querySelector('.logo-card-label').textContent.trim().toLowerCase().replace(/[^a-z0-9]/g, '-');
    
    // Create canvas to render with background
    const canvas = document.createElement('canvas');
    canvas.width = 800;
    canvas.height = 520;
    const ctx = canvas.getContext('2d');
    
    // Get card background color
    const style = getComputedStyle(card);
    const bg = style.backgroundColor;
    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, 800, 520);
    
    // Draw the image centered
    const tempImg = new Image();
    tempImg.crossOrigin = 'anonymous';
    tempImg.onload = function() {
      // Apply CSS filter if present
      const imgStyle = img.style.filter;
      if (imgStyle) {
        ctx.filter = imgStyle;
      }
      const scale = Math.min(520 / tempImg.naturalWidth, 340 / tempImg.naturalHeight);
      const w = tempImg.naturalWidth * scale;
      const h = tempImg.naturalHeight * scale;
      ctx.drawImage(tempImg, (800 - w) / 2, (520 - h) / 2, w, h);
      
      canvas.toBlob(function(blob) {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'tapa-la-pub-' + label + '.png';
        a.click();
        URL.revokeObjectURL(url);
      }, 'image/png');
    };
    tempImg.src = img.src;
  };

  // Nav dots
  const sections = document.querySelectorAll('.section, .footer');
  const dots = document.querySelectorAll('.nav-dot');

  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const index = Array.from(sections).indexOf(entry.target);
        dots.forEach((d, i) => d.classList.toggle('active', i === index));
      }
    });
  }, { threshold: 0.4 });

  sections.forEach(s => sectionObserver.observe(s));

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = dot.dataset.section;
      document.getElementById('s' + idx)?.scrollIntoView({ behavior: 'smooth' });
    });
  });
});
</script>

